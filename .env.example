# App (client) config: set these in app/js/config.local.js as window.__PICKLEBALL_ENV__
# Copy app/js/config.local.sample.js to app/js/config.local.js and add <script src="js/config.local.js"></script> before config.js in index.html.
# SEND_CODE_URL=http://localhost:3081/api/auth/send-code
# VERIFY_CODE_URL=http://localhost:3081/api/auth/verify-code
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# FIREBASE_VAPID_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# ONESIGNAL_APP_ID=
# IP_GEO_URL=https://ipapi.co/json/

# Server (auth): copy server/.env.example to server/.env
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# PORT=3081
# ALLOW_ORIGIN=http://localhost:3080
