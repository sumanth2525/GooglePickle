# Twilio (required for real SMS codes)
# Get from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token

# Verify Service SID (starts with VA...) — create at: Twilio Console → Verify → Services → Create
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Trial accounts: you can only send SMS to verified numbers.
# Add your mobile: Twilio Console → Phone Numbers → Manage → Verified Caller IDs → Add

# Optional: notify event creators when someone joins (push)
# OneSignal Dashboard → Keys & IDs → App ID + REST API Key
# ONESIGNAL_APP_ID=4c67b442-9707-4f07-90df-e68334115088
# ONESIGNAL_REST_API_KEY=your_rest_api_key

PORT=3081
ALLOW_ORIGIN=http://localhost:3080
